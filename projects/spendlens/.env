# Local dev environment variables for SpendLens (Flask + JWT).
#
# Notes:
# - Frontend uses Vite dev proxy, so CORS can be left empty for local dev.
# - In Docker/Render/Vercel, set these via platform config/secret manager.

PORT=8080
FLASK_DEBUG=0

# Session signing secret (used for Flask session cookie + JWT fallback)
SPENDLENS_SECRET=change-me-in-prod

# JWT secret for route protection
JWT_SECRET=change-me-in-prod-and-make-it-long-enough-32+
AUTH_ENABLED=1

# Upload limits
MAX_UPLOAD_BYTES=16777216

# Rate limiting
RATE_LIMIT_DEFAULT=60 per minute

# CORS: set to your deployed frontend origin(s) when running cross-origin.
CORS_ALLOWED_ORIGINS=

