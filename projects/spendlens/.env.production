# Production environment for SpendLens.
PORT=8080
FLASK_DEBUG=0

SPENDLENS_SECRET=change-me-in-prod
JWT_SECRET=change-me-in-prod-and-make-it-long-enough-32+
AUTH_ENABLED=1

MAX_UPLOAD_BYTES=16777216
RATE_LIMIT_DEFAULT=60 per minute

# Example: Vercel frontend + Render backend
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
CORS_ALLOWED_ORIGINS=

