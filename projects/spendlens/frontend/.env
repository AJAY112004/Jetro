#
# Vite environment for SpendLens (dev)
#
# API base path for the browser code. In dev, Vite proxies `/api/*` to Flask.
VITE_API_URL=/api

# Where Vite should proxy `/api/*` to during development.
VITE_API_PROXY_TARGET=http://127.0.0.1:5050

# Dev server host (where your browser connects to).
VITE_DEV_HOST=127.0.0.1

